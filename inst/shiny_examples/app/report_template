```{r setup, include=FALSE}
knitr::opts_chunk$set(echo = FALSE, warning = FALSE, message = FALSE)

dt       <- params$dt
omit_val <- params$omit_val
n_total  <- nrow(dt)
n_pass   <- sum(grepl("No differences", dt$comparison))
n_fail   <- n_total - n_pass

# Pre-render all FAIL diffs
diff_results <- vector("list", n_total)

for (i in seq_len(n_total)) {
  if (grepl("No differences", dt$comparison[i])) next

  comparator <- verifyr2::create_comparator(dt$file1[i], dt$file2[i])
  opts       <- verifyr2::Config$new()
  opts$set("details.mode", "summary")

  details <- tryCatch(
    comparator$vrf_details(config = opts, omit = omit_val),
    error = function(e) {
      list(list(
        type    = "text",
        content = paste0("<p style='color:red;'>Error: ", conditionMessage(e), "</p>")
      ))
    }
  )

  for (d in details) {
    if (d$type == "text") {
      diff_results[[i]] <- as.character(d$content)
    } else if (d$type == "image") {
      img1 <- d$content$image1
      img2 <- d$content$image2
      img3 <- d$content$image3
      diff_results[[i]] <- paste0(
        "<div style='display:flex;gap:12px;flex-wrap:wrap;'>",
        "<div style='flex:1;min-width:200px;'>",
        "<div class='path-label'>Base</div>",
        "<img src='", img1, "' style='width:100%;border:1px solid #eee;'/>",
        "</div>",
        "<div style='flex:1;min-width:200px;'>",
        "<div class='path-label'>Compare</div>",
        "<img src='", img2, "' style='width:100%;border:1px solid #eee;'/>",
        "</div>",
        if (!is.null(img3)) paste0(
          "<div style='flex:1;min-width:200px;'>",
          "<div class='path-label'>Difference</div>",
          "<img src='", img3, "' style='width:100%;border:1px solid #eee;'/>",
          "</div>"
        ) else "",
        "</div>"
      )
    }
  }
}
```

