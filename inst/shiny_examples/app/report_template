## Summary

```{r summary_table}
{
  is_match <- grepl("No differences", dt$comparison)
  status_html <- ifelse(
    is_match,
    "<span class='badge-match' style='padding:2px 8px;border-radius:20px;font-size:11px;font-weight:700;background:#e8f5d0;color:#5a8a20;'>Match</span>",
    "<span class='badge-mismatch' style='padding:2px 8px;border-radius:20px;font-size:11px;font-weight:700;background:#fde9e0;color:#c04820;'>Mismatch</span>"
  )
  knitr::kable(
    data.frame(
      File     = basename(dt$file1),
      Result   = dt$comparison,
      Status   = status_html,
      Comments = ifelse(
        !is.null(dt$comments_details) & dt$comments_details != "",
        dt$comments_details,
        "\u2014"
      ),
      stringsAsFactors = FALSE
    ),
    format  = "html",
    align   = c("l", "l", "c", "l"),
    escape  = FALSE
  )
}
