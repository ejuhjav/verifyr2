```{r setup, include=FALSE}
knitr::opts_chunk$set(echo = FALSE, warning = FALSE, message = FALSE)
library(knitr)
library(kableExtra)

dt       <- params$dt
omit_val <- params$omit_val
n_total  <- nrow(dt)
n_pass   <- sum(grepl("No differences", dt$comparison))
n_fail   <- n_total - n_pass

# ── Pre-render all FAIL diffs and collect <style> tags ────────────────────────
# diffobj injects <style> blocks that must live in <head>. We collect them here
# and emit them once at the top; the body HTML has them stripped out.
diff_results  <- vector("list", n_total)

for (i in seq_len(n_total)) {
  is_pass <- grepl("No differences", dt$comparison[i])
  if (is_pass) next

  # Always create a fresh comparator with a fresh config
  comparator <- verifyr2::create_comparator(dt$file1[i], dt$file2[i])
  opts <- verifyr2::Config$new()
  opts$set("details.mode", "summary")
  omit_param <- if (!is.null(params$omit_val) && params$omit_val != "") params$omit_val else NULL
  details <- tryCatch(
    comparator$vrf_details(config = opts, omit = omit_param),
    error = function(e) list(list(type = "text", content = paste0("<p style='color:red;'>Error: ", conditionMessage(e), "</p>")))
  )

  for (d in details) {
    if (d$type == "text") {
      # Store content as-is — styles are inline and render fine in self_contained HTML
      diff_results[[i]] <- as.character(d$content)
    }
  }
}
```


