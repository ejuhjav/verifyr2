## Details

```{r details, results='asis'}
for (i in seq_len(nrow(dt))) {
  file1   <- dt$file1[i]
  file2   <- dt$file2[i]
  result  <- dt$comparison[i]
  comment <- dt$comments_details[i]
  is_pass <- grepl("No differences", result)
  status  <- if (is_pass) "Match" else "Mismatch"

  cat(paste0(
    "\n<div class='file-section ", if (is_pass) "file-match" else "file-mismatch", "'>",

    "<div class='file-header'>",
    "<strong class='file-name'>", basename(file1), "</strong>",
    "<span class='status-badge ", if (is_pass) "badge-match" else "badge-mismatch", "'>",
    status, "</span>",
    "</div>",

    "<div class='file-paths'>",
    "<span class='path-label'>Base</span><br/>", file1, "<br/>",
    "<span class='path-label'>Compare</span><br/>", file2,
    "</div>",

    "<div class='file-result'>",
    "<span>", result, "</span>",
    if (!is.null(comment) && comment != "")
      paste0("<div class='comment-box'><strong>Comment:</strong> ", comment, "</div>")
    else "",
    "</div>"
  ))

  if (is_pass) {
    cat("<div class='diff-output match-message'>&#10003;&nbsp; Files are identical.</div>")
  } else {
    diff_html <- diff_results[[i]]
    cat("<div class='diff-output'>")
    if (!is.null(diff_html) && nchar(diff_html) > 0) {
      cat(diff_html)
    } else {
      cat(paste0("<p class='no-diff'>", result, "</p>"))
    }
    cat("</div>")
  }

  cat("</div>\n")
}
```
